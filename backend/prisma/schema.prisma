// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum GameType {
  EyeFold
  NightFall
}

enum Role {
  Quanbit
  Human
}

enum Winner {
  Quanbit
  Human
}

model Game {
  id       String    @id @default(cuid())
  type     GameType
  active   Boolean   @default(true)
  startAt  DateTime  @default(now())
  endAt    DateTime?
  duration Int
  winner   Winner?

  players Player[]
  chats   Chat[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  votes     Vote[]
}

model Player {
  id String @id @default(cuid())

  gameId String
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  role   Role    @default(Human)
  kicked Boolean @default(false)

  sentChats     Chat[] @relation("ChatSender")
  receivedChats Chat[] @relation("ChatReceiver")
}

model Chat {
  id   String @id @default(cuid())
  text String

  gameId String
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  playerId String
  player   Player @relation("ChatSender", fields: [playerId], references: [id])

  toPlayerId String?
  toPlayer   Player? @relation("ChatReceiver", fields: [toPlayerId], references: [id])

  createdAt DateTime @default(now())
}

model Vote {
  id     String @id @default(cuid())
  gameId String
  game   Game   @relation(fields: [gameId], references: [id])

  voterId  String
  targetId String

  round  Int     @default(1)
  reason String?

  createdAt DateTime @default(now())

  @@unique([gameId, voterId, round])
  @@index([gameId, targetId])
}
